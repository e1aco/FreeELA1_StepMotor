                "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32F1xx/Include/**",
                "${workspaceFolder}/Drivers/CMSIS/Include/**",
                "${workspaceFolder}/Ctrl/**",
                "${workspaceFolder}/Ctrl/Driver/**",
                "${workspaceFolder}/Ctrl/Motor/**",
                "${workspaceFolder}/Ctrl/Sensor/**",
                "${workspaceFolder}/Ctrl/Signal/**",
                "${workspaceFolder}/UserApp/**",
                "${workspaceFolder}/Port/**",
                "${workspaceFolder}/Port/Platform/**",
                "${workspaceFolder}/Port/Platform/Memory/**",
                "${workspaceFolder}/Port/Platform/Utils/**"
            ],
            "defines": [
                "USE_HAL_DRIVER",
                "__MICROLIB",
